# SigDoc — Environment Variables Reference
# Copy this file to .env and fill in your values.

# ── Database
# PostgreSQL async connection string (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://sigdoc:secret@localhost:5432/sigdoc

# ── Auth / Security
# Random secret used to sign JWT tokens — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-a-random-hex-secret

# Email of the auto-seeded admin user (created on first startup)
ADMIN_EMAIL=admin@sigdoc.local

# Password for the auto-seeded admin user
ADMIN_PASSWORD=admin123

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MinIO (object storage)
# Internal hostname used by the backend to reach MinIO (e.g. Docker service name)
MINIO_ENDPOINT=minio:9000

# External hostname used to build presigned download URLs for clients
MINIO_EXTERNAL_ENDPOINT=localhost:9000

# MinIO access key (username)
MINIO_ACCESS_KEY=minioadmin

# MinIO secret key (password)
MINIO_SECRET_KEY=minioadmin

# Set to true if MinIO is behind HTTPS
MINIO_SECURE=false

# ── CORS
# Comma-separated list of allowed origins for Cross-Origin requests.
# Use * to allow all origins (development only).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Bulk Generation
# Maximum number of rows allowed in a single bulk generation request
BULK_GENERATION_LIMIT=10

# ── Rate Limits
# slowapi rate limit strings — format: <count>/<period> (e.g. 5/minute, 100/hour)
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_GENERATE=20/minute
RATE_LIMIT_GENERATE_BULK=5/minute

# ── PDF Conversion (Gotenberg)
# Internal URL of the Gotenberg service (used by the backend to convert DOCX → PDF)
GOTENBERG_URL=http://gotenberg:3000

# Timeout in seconds for a single DOCX-to-PDF conversion request
GOTENBERG_TIMEOUT=60
