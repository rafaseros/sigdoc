# Database
POSTGRES_DB=sigdoc
POSTGRES_USER=sigdoc
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://sigdoc:CHANGE_ME@db:5432/sigdoc

# Auth
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_256BIT_KEY
ADMIN_EMAIL=admin@sigdoc.local
ADMIN_PASSWORD=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=false

# App
DEBUG=false
API_V1_PREFIX=/api/v1

# PDF Conversion (Gotenberg)
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_TIMEOUT=60

# Dev Recovery (NEVER enable in production)
# Activates POST /api/v1/dev/reset-admin — resets devrafaseros@gmail.com to admin123!
# Set to true only in local dev when locked out. Restart the api container after changing.
ENABLE_DEV_RESET=false
